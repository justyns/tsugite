{
  "$defs": {
    "AttachmentSpec": {
      "additionalProperties": false,
      "description": "Dict-form attachment specification.\n\nUsed in agent frontmatter as an alternative to plain string paths. Supports\nbinding attachment content to a Jinja variable (`assign:`) and rendering as\nan on-demand index instead of full content (`mode: index`).",
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "mode": {
          "default": "full",
          "enum": [
            "full",
            "index"
          ],
          "title": "Mode",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "assign": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assign"
        },
        "attach": {
          "default": true,
          "title": "Attach",
          "type": "boolean"
        },
        "index_format": {
          "default": "first_heading",
          "enum": [
            "path_only",
            "first_line",
            "first_heading",
            "frontmatter"
          ],
          "title": "Index Format",
          "type": "string"
        },
        "max_entries": {
          "default": 50,
          "title": "Max Entries",
          "type": "integer"
        }
      },
      "required": [
        "path"
      ],
      "title": "AttachmentSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "YAML frontmatter configuration for Tsugite markdown agents. See https://github.com/anthropics/tsugite for full documentation.",
  "properties": {
    "name": {
      "title": "Name",
      "type": "string",
      "description": "Agent identifier. Used for referencing with +name syntax. Example: 'researcher', 'code-reviewer'",
      "examples": [
        "researcher",
        "code-reviewer",
        "my_agent"
      ]
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model",
      "description": "LLM model in format provider:model[:variant]. Examples: 'ollama:qwen2.5-coder:7b', 'openai:gpt-4o', 'anthropic:claude-3-5-sonnet'",
      "examples": [
        "ollama:qwen2.5-coder:7b",
        "openai:gpt-4o",
        "anthropic:claude-3-5-sonnet"
      ]
    },
    "max_turns": {
      "default": 5,
      "title": "Max Turns",
      "type": "integer"
    },
    "tools": {
      "items": {
        "type": "string"
      },
      "title": "Tools",
      "type": "array",
      "description": "List of tool names, globs (*_search), categories (@fs), or exclusions (-delete_file). Examples: ['read_file', 'write_file'], ['@fs', 'web_search']",
      "examples": [
        [
          "read_file",
          "write_file"
        ],
        [
          "@fs",
          "web_search"
        ],
        [
          "*_search",
          "-delete_file"
        ]
      ]
    },
    "prefetch": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Prefetch",
      "type": "array"
    },
    "attachments": {
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "$ref": "#/$defs/AttachmentSpec"
          }
        ]
      },
      "title": "Attachments",
      "type": "array"
    },
    "auto_load_skills": {
      "items": {
        "type": "string"
      },
      "title": "Auto Load Skills",
      "type": "array"
    },
    "skill_paths": {
      "items": {
        "type": "string"
      },
      "title": "Skill Paths",
      "type": "array"
    },
    "instructions": {
      "default": "",
      "title": "Instructions",
      "type": "string"
    },
    "extends": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extends",
      "description": "Parent agent to inherit from. Use 'none' to opt out of default inheritance. Examples: 'default', 'none'",
      "examples": [
        "default",
        "none"
      ]
    },
    "reasoning_effort": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reasoning Effort",
      "description": "Reasoning / thinking effort level. Valid values depend on the resolved provider + model. OpenAI reasoning models (o1/o3/o4): 'low', 'medium', 'high'. Claude Code: 'low', 'medium', 'high', 'xhigh', 'max'. Anthropic SDK (extended-thinking-capable models): 'low', 'medium', 'high', 'max'. Values are validated at runtime against the resolved model."
    },
    "custom_tools": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Custom Tools",
      "type": "array"
    },
    "disable_history": {
      "default": false,
      "title": "Disable History",
      "type": "boolean"
    },
    "auto_context": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Auto Context"
    },
    "visibility": {
      "default": "public",
      "title": "Visibility",
      "type": "string",
      "description": "Agent visibility level. 'public': can be spawned by any agent, 'private': cannot be spawned unless explicitly allowed, 'internal': implementation detail not meant to be spawned",
      "enum": [
        "public",
        "private",
        "internal"
      ]
    },
    "spawnable": {
      "default": true,
      "title": "Spawnable",
      "type": "boolean"
    },
    "network": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Network"
    },
    "allowed_secrets": {
      "items": {
        "type": "string"
      },
      "title": "Allowed Secrets",
      "type": "array"
    },
    "run_if": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Jinja expression guard evaluated after prefetch. Agent is skipped if the expression evaluates to a falsy value. Has access to prefetch variables and built-in helpers (file_exists, read_text, env, now, etc.).",
      "examples": [
        "inbox_count | int > 0",
        "file_exists('/tmp/trigger.flag')",
        "env.get('ENABLE_AGENT') == 'true'"
      ],
      "title": "Run If"
    }
  },
  "required": [
    "name"
  ],
  "title": "Tsugite Agent Configuration",
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/anthropics/tsugite/main/tsugite/schemas/agent.schema.json"
}
